# Copy this file to .env and fill in the blanks:
#   cp .env.example .env
#
# docker-compose.yml reads this automatically (docker compose / Portainer
# both auto-load a .env file sitting next to the compose file). .env itself
# is gitignored so real TOKEN/KEY values never get committed - only this
# .env.example template is tracked.
#
# In Portainer's "Repository" stack mode, you can either commit a real .env
# next to the compose file on a private repo/branch you control, or leave
# TOKEN/KEY out of .env entirely and set them in the stack's own
# "Environment variables" field in the Portainer UI instead - either layers
# on top of the other, Portainer's UI values win if both are set.

# Public URL the hub is reachable at. Only change this if it's not
# localhost:8090 (e.g. reverse-proxied behind a domain).
APP_URL=http://localhost:8090

# Host port to publish the hub's web UI/API on.
HUB_PORT=8090

# URL the agent uses to reach the hub. Defaults to the same-host case.
HUB_URL=http://localhost:8090

# TOKEN and KEY come from the hub's "Add System" dialog - they don't exist
# until the hub has booted once. Leave these blank on first deploy, start
# just the "beszel" service, open the hub UI, add a system to get real
# values, then fill these in and redeploy.
TOKEN=
KEY=
