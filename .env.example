# Copy this file to .env and fill in the blanks:
#   cp .env.example .env
#
# Both docker-compose.yml (hub) and docker-compose.agent.yml (agent) read
# this automatically (docker compose / Portainer both auto-load a .env file
# sitting next to the compose file being used). .env itself is gitignored
# so real TOKEN/KEY values never get committed - only this .env.example
# template is tracked.
#
# In Portainer's "Repository" stack mode, you can either commit a real .env
# next to the compose file on a private repo/branch you control, or leave
# these out of .env entirely and set them in each stack's own "Environment
# variables" field in the Portainer UI instead - either layers on top of
# the other, Portainer's UI values win if both are set.

# --- docker-compose.yml (hub) ---

# Public URL the hub is reachable at. Only change this if it's not
# localhost:8090 (e.g. reverse-proxied behind a domain).
APP_URL=http://localhost:8090

# Host port to publish the hub's web UI/API on.
HUB_PORT=8090

# --- docker-compose.agent.yml (agent) ---

# Port the agent listens on for the hub's SSH connection.
AGENT_LISTEN=45876

# URL the agent uses to reach the hub. If the agent runs on a different
# host than the hub, use that host's address instead of localhost.
HUB_URL=http://localhost:8090

# TOKEN and KEY come from the hub's "Add System" dialog - they don't exist
# until the hub has booted once. Deploy docker-compose.yml first, open the
# hub UI, add a system to get real values, then fill these in before
# deploying docker-compose.agent.yml.
TOKEN=
KEY=
